journal = {Clinical chemistry},
keywords = {16S,16S: chemistry,16S: genetics,Bacterial,Bacterial: chemistry,Bacterial: genetics,Computational Biology,DNA,DNA: methods,Genomics,Genomics: methods,Humans,Metagenome,RNA,Ribosomal,Sequence Analysis},
month = may,
number = {5},
pages = {856--866},
pmid = {19264858},
title = {{Metagenomic pyrosequencing and microbial identification.}},
