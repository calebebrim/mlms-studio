journal = {Talanta},
keywords = {Cell Nucleus,Mass Spectrometry,Mass Spectrometry: methods,Spectrometry, Mass, Matrix-Assisted Laser Desorpti,Viral Proteins,Viral Proteins: blood},
month = feb,
number = {4},
pages = {1561--8},
pmid = {20082815},
title = {{Monitoring virus-like particle and viral protein production by intact cell MALDI-TOF mass spectrometry.}},
url = {http://www.ncbi.nlm.nih.gov/pubmed/20082815},
volume = {80},
year = {2010}
