@article{Giebel2010,
abstract = {Recent threats posed by pathogenic microorganisms in food, recreational waters, and as agents of bioterror have underscored the need for the development of more rapid, accurate, and cost-effective methods of microbial characterization and identification. This chapter focuses on the use of matrix-assisted laser desorption ionization time-of-flight mass spectrometry (MALDI-TOF MS) to rapidly characterize and identify microorganisms through generation of characteristic fingerprints of intact cells. While most efforts have focused on bacteria, this technology has also been applied to fungi and viruses. Results of most studies suggest that MALDI-TOF MS can be used to rapidly and accurately characterize microorganisms. A variety of quantitative approaches have been employed in the analysis of MALDI-TOF MS fingerprints of microorganisms. The reproducibility of fingerprints of intact cells remains a primary concern and limitation associated with this approach. Protocols and instrumentation used have varied considerably and likely account for much of the variability in reproducibility reported. Key first steps to overcoming this limitation will be the development of standard approaches to quantifying reproducibility and the development of standard protocols for sample preparation and analysis.},
author = {Giebel, R and Worden, C and Rust, SM},
doi = {10.1016/S0065-2164(10)71006-6},
