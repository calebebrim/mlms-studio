file = {:Users/calebebrim/Dropbox/artigos/organized/Giebel, Worden, Rust/Advances in applied \ldots/Giebel, Worden, Rust - 2010 - Microbial fingerprinting using matrix-assisted laser desorption ionization time-of-flight mass spectrometr.pdf:pdf},
