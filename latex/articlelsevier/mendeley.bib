journal = {PLoS pathogens},
keywords = {Adenoviruses, Human,Adenoviruses, Human: genetics,Child, Preschool,Computational Biology,Computational Biology: methods,Diarrhea, Infantile,Diarrhea, Infantile: diagnosis,Diarrhea, Infantile: virology,Feces,Feces: microbiology,Gastroenteritis,Gastroenteritis: virology,Gene Library,Genome, Viral,Genome, Viral: genetics,Genomics,Genomics: methods,Humans,Infant,Phylogeny,Sequence Analysis, DNA,Viruses,Viruses: classification,Viruses: genetics,Viruses: isolation \& purification},
month = feb,
number = {2},
pages = {e1000011},
pmid = {18398449},
title = {{Metagenomic analysis of human diarrhea: viral detection and discovery.}},
url = {http://www.pubmedcentral.nih.gov/articlerender.fcgi?artid=2290972\&tool=pmcentrez\&rendertype=abstract},
volume = {4},
year = {2008}
}
@article{Franco2010,
abstract = {A new application of intact cell MALDI-TOF MS (ICM-MS) methodology is described for monitoring the production of viral proteins and viral like particles using the baculovirus/insect cells expression system. Various MALDI matrices, cell preparation methods, cell/matrix volume ratio and MALDI target application procedures were tested in order to obtain the highest intensity and reproducibility of intact insect cell spectra. The web interface, SPECLUST (http://bioinfo.thep.lu.se/speclust.html), was used to construct dendograms based on MALDI-TOF MS data for evaluation of fingerprint changes. We demonstrate that insect cell mass spectrum fingerprints are characteristic of each viral protein/particle production. Their changes along the time for each production experiment correlate with the intracellular viral protein content determined by Western blot. This work shows that this simple, fast and low cost assay, which requires low sample volume, is a powerful analytical tool that complements the most common analytical methods used for monitoring bioprocesses and has potential application in the biotechnological industry namely, in the production of recombinant proteins.},
author = {Franco, Catarina F and Mellado, Maria C\^{a}ndida M and Alves, Paula M and Coelho, Ana V},
doi = {10.1016/j.talanta.2009.06.081},
file = {:Users/calebebrim/Dropbox/artigos/organized/Franco et al/Talanta/Franco et al. - 2010 - Monitoring virus-like particle and viral protein production by intact cell MALDI-TOF mass spectrometry.pdf:pdf},
