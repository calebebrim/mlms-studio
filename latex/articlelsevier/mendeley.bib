@article{Wulfkuhle2003,
abstract = {The ability of physicians to effectively treat and cure cancer is directly dependent on their ability to detect cancers at their earliest stages. Proteomic analyses of early-stage cancers have provided new insights into the changes that occur in the early phases of tumorigenesis and represent a new resource of candidate biomarkers for early-stage disease. Studies that profile proteomic patterns in body fluids also present new opportunities for the development of novel, highly sensitive diagnostic tools for the early detection of cancer.},
author = {Wulfkuhle, Julia D and Liotta, Lance a and Petricoin, Emanuel F},
doi = {10.1038/nrc1043},
file = {:Users/calebebrim/Dropbox/artigos/organized/Wulfkuhle, Liotta, Petricoin/Nature reviews Cancer/Wulfkuhle, Liotta, Petricoin - 2003 - Proteomic applications for the early detection of cancer.pdf:pdf},
isbn = {1474-175X},
issn = {1474-175X},
journal = {Nature reviews Cancer},
number = {April},
pages = {267--275},
pmid = {12671665},
title = {{Proteomic applications for the early detection of cancer.}},
volume = {3},
year = {2003}
}
@article{Yang2009,
abstract = {BACKGROUND: In mass spectrometry (MS) based proteomic data analysis, peak detection is an essential step for subsequent analysis. Recently, there has been significant progress in the development of various peak detection algorithms. However, neither a comprehensive survey nor an experimental comparison of these algorithms is yet available. The main objective of this paper is to provide such a survey and to compare the performance of single spectrum based peak detection methods.

RESULTS: In general, we can decompose a peak detection procedure into three consequent parts: smoothing, baseline correction and peak finding. We first categorize existing peak detection algorithms according to the techniques used in different phases. Such a categorization reveals the differences and similarities among existing peak detection algorithms. Then, we choose five typical peak detection algorithms to conduct a comprehensive experimental study using both simulation data and real MALDI MS data.

CONCLUSION: The results of comparison show that the continuous wavelet-based algorithm provides the best average performance.},
author = {Yang, Chao and He, Zengyou and Yu, Weichuan},
doi = {10.1186/1471-2105-10-4},
file = {:Users/calebebrim/Dropbox/artigos/organized/Yang, He, Yu/BMC bioinformatics/Yang, He, Yu - 2009 - Comparison of public peak detection algorithms for MALDI mass spectrometry data analysis.pdf:pdf},
isbn = {1471210510},
issn = {1471-2105},
journal = {BMC bioinformatics},
keywords = {Algorithms,Artificial Intelligence,Computational Biology,Computational Biology: methods,Data Interpretation, Statistical,Humans,Mass Spectrometry,Mass Spectrometry: methods,Models, Statistical,Normal Distribution,Pattern Recognition, Automated,Pattern Recognition, Automated: methods,Peptides,Peptides: chemistry,Proteomics,Proteomics: methods,Signal Processing, Computer-Assisted,Software,Spectrometry, Mass, Matrix-Assisted Laser Desorpti,Statistics as Topic,Statistics as Topic: methods},
month = jan,
pages = {4},
pmid = {19126200},
title = {{Comparison of public peak detection algorithms for MALDI mass spectrometry data analysis.}},
url = {http://www.pubmedcentral.nih.gov/articlerender.fcgi?artid=2631518\&tool=pmcentrez\&rendertype=abstract},
volume = {10},
year = {2009}
}
