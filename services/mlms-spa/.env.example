# Origem do BFF (prefixo global /api/v1 no Nest). Em dev com `npm run dev`, use o proxy:
VITE_MLMS_API_BASE=/api/v1
# Sem proxy (BFF acessível diretamente no browser):
# VITE_MLMS_API_BASE=http://127.0.0.1:3000/api/v1
VITE_REALTIME_WS_URL=wss://localhost:3000/realtime
# Opcional: lido só pelo processo Node do Vite (sem prefixo VITE_). Se o worker usar
# MLMS_WORKER_INTERNAL_TOKEN, defina o mesmo valor aqui para o proxy injetar Bearer.
# MLMS_WORKER_INTERNAL_TOKEN=
