# Vite dev server (Tilt / Compose — proxy /api → BFF; override com MLMS_API_PROXY_TARGET).
FROM node:22-bookworm-slim
WORKDIR /app
COPY package.json ./
RUN npm install
COPY . .
ENV MLMS_API_PROXY_TARGET=http://127.0.0.1:3000
EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
