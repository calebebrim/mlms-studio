# MLMS Studio — variáveis de ambiente (exemplo versionado).
# Copie para `.env` na raiz do repositório e preencha valores reais.
# Nunca commite `.env` (ver `.gitignore` e docs/security/secrets-gcp-tilt-ci.md).

# --- Docker Compose / Tilt (local) ---
# Pasta no *host* montada em /var/mlms/data no container mlms-api (datasets, uploads, datasets.json).
# Caminho relativo ao ficheiro compose.yaml na raiz do repo ou caminho absoluto (útil em WSL/Docker Desktop).
# Por omissão, se omitir a variável: ./services/mlms-api/data
# MLMS_HOST_DATA_DIR=./services/mlms-api/data
# MLMS_HOST_DATA_DIR=/caminho/absoluto/para/mlms-dados-local

# URL do worker para o proxy do Vite dentro do container `web` (legado / testes diretos).
MLMS_WORKER_PROXY_TARGET=http://mlms-worker:8080
# Proxy `/api` → BFF Nest no Compose.
MLMS_API_PROXY_TARGET=http://mlms-api:3000

# --- mlms-worker (Rust) ---
MLMS_WORKER_PORT=8080
# Opcional: se definido, POST /v1/jobs exige Authorization: Bearer <token>.
# Repetir o mesmo valor no serviço web (Compose) para o proxy Vite injetar em dev.
# MLMS_WORKER_INTERNAL_TOKEN=
# JSON estruturado em Cloud Logging: json | texto
# MLMS_LOG_FORMAT=json

# --- mlms-api (NestJS BFF) ---
# Volume montado para uploads de datasets e `datasets.json` (Compose usa /var/mlms/data).
# MLMS_DATA_VOLUME_PREFIX=/var/mlms/data
# MLMS_DATASETS_STORE_PATH=/var/mlms/data/datasets.json
# No Compose, o BFF também usa o mesmo volume para experiências (evita mkdir em /app/var).
# MLMS_EXPERIMENTS_STORE_PATH=/var/mlms/data/experiments.json
# Porta HTTP do BFF (Compose expõe 3000:3000).
# PORT=3000
# URL base do worker visto pelo BFF (Compose: rede interna).
# MLMS_WORKER_URL=http://mlms-worker:8080
# Em dev host (sem Compose): http://127.0.0.1:8080
# MLMS_WORKER_URL=http://127.0.0.1:8080
# Mesmo segredo que MLMS_WORKER_INTERNAL_TOKEN no worker (só serviço-a-serviço).
# MLMS_WORKER_INTERNAL_TOKEN=

# Prefixo do volume de dados: `storage_ref` nos datasets é validado como caminho lógico sob este root (sem `..`).
# MLMS_DATA_VOLUME_PREFIX=data
# Ficheiro JSON de metadados dos datasets (CRUD lógico); omitir para `var/datasets.json` sob cwd do processo.
# MLMS_DATASETS_STORE_PATH=var/datasets.json
# Experiências / revisões append-only de PipelineSpec (MVP: ficheiro JSON semelhante a datasets).
# MLMS_EXPERIMENTS_STORE_PATH=var/experiments.json

# --- API Node (OAuth/sessão futuros) — Secret Manager / .env local ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# SESSION_SECRET=
# DATABASE_URL=

# --- Front (Vite) — ver também services/mlms-spa/.env.example ---
# Prefixo VITE_* é exposto ao browser: não colocar segredos.
# Base do BFF (path /api/v1 no mesmo host do dev server, via proxy).
# VITE_MLMS_API_BASE=/api/v1
# VITE_REALTIME_WS_URL=
